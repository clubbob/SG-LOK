{
  "name": "sglok",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "npx --yes rimraf@5 .next .next-alt",
    "dev": "node scripts/dev.mjs",
    "dev:clean": "npm run clean && npm run dev",
    "dev:refresh": "npm run clean && node scripts/dev.mjs",
    "dev:3000": "next dev --port 3000",
    "dev:auto": "cross-env DEV_AUTO_PORT=1 node scripts/dev.mjs",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "build:turbo": "next build --turbopack",
    "start": "next start --port 3000",
    "lint": "eslint",
    "export": "next build",
    "deploy": "npm run export && firebase deploy --only hosting",
    "import:mappings": "node scripts/importSubstituteMappingsFromSheet.mjs",
    "import:swagelok-catalog": "node scripts/importSwagelokCatalogPdf.mjs",
    "export:swagelok-catalog-seed": "node scripts/importSwagelokCatalogPdf.mjs --export-json=src/data/swagelokCatalogTubeFittingSeed.json",
    "prune:swagelok-catalog-firestore": "node scripts/pruneSwagelokCatalogFirestore.mjs"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.4",
    "clsx": "^2.1.1",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.4.0",
    "jspdf": "^3.0.4",
    "next": "^15.5.14",
    "nodemailer": "^7.0.11",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "get-port": "^7.2.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
