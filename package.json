{
  "name": "sglok",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "npx --yes rimraf@5 .next .next-alt",
    "dev": "cross-env NEXT_USE_ALT_DIST=1 next dev",
    "dev:classic": "next dev",
    "dev:alt": "cross-env NEXT_USE_ALT_DIST=1 next dev",
    "dev:clean": "npm run clean && npm run dev",
    "dev:turbo": "cross-env NEXT_USE_ALT_DIST=1 next dev --turbopack",
    "build": "next build",
    "build:alt": "cross-env NEXT_USE_ALT_DIST=1 next build",
    "build:clean": "npm run clean && npm run build",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "export": "next build",
    "deploy": "npm run export && firebase deploy --only hosting"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.4",
    "clsx": "^2.1.1",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.4.0",
    "jspdf": "^3.0.4",
    "next": "^15.5.14",
    "nodemailer": "^7.0.11",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
